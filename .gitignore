node_modules/
dist/
coverage/
.env
.env.local
*.log
.DS_Store
.vscode/
.idea/

# Per-user Claude Code state. settings.local.json is auto-generated by the
# Claude CLI; worktrees/ is populated if the user enables experimental agent
# teams. Neither is shared across contributors.
.claude/settings.local.json
.claude/worktrees/

# Local runtime memory — contains per-user yentaIds and learned agent/team
# patterns. Never commit. Setup.sh copies the corresponding .template files
# into place on first install.
memory/user-preferences.md
memory/user-patterns.md

# Playwright MCP probe artifacts (DOM snapshots, network traces, screenshots
# from exploratory Bolt UI investigation). Root-only patterns so docs/ PNGs
# and CI workflow YAMLs are unaffected.
.playwright-mcp/
/*.yml
/referral-*.json
/referral-*.txt
/*.png
